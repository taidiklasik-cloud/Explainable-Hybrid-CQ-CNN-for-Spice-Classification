# Copy this file to .env and fill in local/private values.
# Never commit .env, rclone.conf, database passwords, Supabase keys, or worker tokens.

# Orchestration PostgreSQL.
# Stores stage/task/worker/heartbeat/checkpoint metadata only.
# This can point to local PostgreSQL or Supabase PostgreSQL, depending on deployment.
ORCHESTRATION_DB_DSN=postgresql://<user>:<password>@<host>:5432/cqcnn_orchestration

# Optuna PostgreSQL RDB storage.
# Authoritative source for study, trial, sampled hyperparameters, objective values,
# and best-trial metadata.
OPTUNA_STORAGE_URL=postgresql+psycopg2://<user>:<password>@<host>:5432/optuna_skripsi

# Worker identity and runtime behavior.
WORKER_UID=worker_local_01
WORKER_NAME=worker-local-01
WORKER_ROLE=worker
WORKER_STALE_AFTER_SECONDS=900
WORKER_OFFLINE_AFTER_SECONDS=120
USE_PG_CRON=false

# Dataset and curriculum locations.
DATASET_ROOT=dataset_cleaned_preprocessed
CURRICULUM_OUTPUTS_ROOT=curriculum_outputs

# Checkpoint policy.
# Physical .pt files must stay outside PostgreSQL. PostgreSQL stores metadata only.
WORKER_LOCAL_CHECKPOINT_ROOT=outputs/checkpoint_cache
CHECKPOINT_INTERVAL_EPOCHS=1
REQUIRE_CHECKPOINT_UPLOAD=false
STORE_CHECKPOINT_BLOB_IN_DB=false

# Current helper implementation: Google Drive-compatible rclone backend.
# If the deployment uses Supabase Storage, keep real keys in .env or a secret manager
# and do not commit them.
CHECKPOINT_STORAGE_BACKEND=gdrive_rclone
RCLONE_REMOTE_NAME=gdrive
GDRIVE_CHECKPOINT_ROOT=cqcnn_checkpoints
RCLONE_EXE_PATH=rclone
RCLONE_CONFIG_PATH=
